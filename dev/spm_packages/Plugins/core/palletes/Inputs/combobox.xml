<?xml version="1.0"?>
<Geety xmlns:G="Geety" xmlns:F="Fobox">
    <ComboBox G:Extends="select">
        <F:Name>Выпадающий список</F:Name>
        <F:Properties>
            <F:Property type="TEXT" key="value" name="Значение">
                <F:PropertyOnLoad>
                    <![CDATA[ 
                        (element) => {
                            return element.value
                        }
                    ]]>
                </F:PropertyOnLoad>
                <F:PropertyOnChange>
                    <![CDATA[ 
                        (element, value) => {
                            element.value = value
                        }
                    ]]>
                </F:PropertyOnChange>
            </F:Property>
        </F:Properties>
        <option value="день рождения">День рождения</option>
        <option value="8 марта">8 Марта</option>
        <option value="новый год">Новый год</option>
        <option value="свадьба">Свадьба</option>
        <option value="просто так">Просто так</option>
    </ComboBox>
</Geety>