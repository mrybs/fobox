<?xml version="1.0"?>
<Geety xmlns:G="Geety" xmlns:DB="DB@1">
    <View>
        <FoboxBase/>
        <G:Page
            title="Панель администратора | Fobox"
            robots="noindex, nofollow"/>
        <Header/>

        <div>
            <SidePane type="'left'" class="'sidepane-with-footer'">
                <div>
                    <a onclick="G.redirect(`/fobox`)">Главная</a>
                    <a onclick="G.redirect(`/fobox/pages`)">Страницы</a>
                </div>
                <div>
                   © "Миот" 2026
                </div>
            </SidePane>
            
            <div>
                <Content>
                    <h1>Добро пожаловать в Фобокс $FOBOX_VERSION</h1>

                    <Cover src="'/fobox/res/cover.png'"/>
                </Content>
                <Content>
                    <h2>Пользователи</h2>
                    <DB:Query id="users" collection="_fobox_users">
                        <DB:Find order="ASC id"/>
                    </DB:Query>
                    <G:For each="user:users">
                        <LICard>
                            $user.name#$user.id
                            <G:If cond="$user.role == 2">
                                <span style="'color:crimson;font-weight:bold;'">[ADMIN]</span>
                            </G:If>
                        </LICard>
                    </G:For>
                </Content>
            </div>
        </div>
    </View>
</Geety>