<?xml version="1.0"?>
<Geety xmlns:G="Geety">
    <Table G:Extends="table" id="$id" class="table">
        <G:Arg name="id"/>

        <style>
            .table{
                border-collapse: collapse;
            }
            .table tr>*{
                padding: 10px 5px;
                border-top: 1px solid var(--border);
                white-space: nowrap;
            }
            .table tr:first-of-type>*{
                border-top: none;
            }
            .table tr>.stretch{
                width: 100%;
            }
        </style>

        <G:Content/>
    </Table>
</Geety>